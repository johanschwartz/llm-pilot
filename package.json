{
  "name": "llm-pilot",
  "displayName": "LLM Pilot",
  "description": "Agentic AI coding assistant powered by local LLMs",
  "version": "0.2.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "llmPilot.openChat",
        "title": "LLM Pilot: Open Chat"
      },
      {
        "command": "llmPilot.inlineEdit",
        "title": "LLM Pilot: Inline Edit Selection"
      },
      {
        "command": "llmPilot.explainCode",
        "title": "LLM Pilot: Explain Code"
      },
      {
        "command": "llmPilot.fixError",
        "title": "LLM Pilot: Fix Diagnostic Error"
      },
      {
        "command": "llmPilot.selectModel",
        "title": "LLM Pilot: Select Model"
      }
    ],
    "keybindings": [
      {
        "command": "llmPilot.openChat",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o"
      },
      {
        "command": "llmPilot.inlineEdit",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "LLM Pilot",
      "properties": {
        "llmPilot.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "llmPilot.model": {
          "type": "string",
          "default": "qwen3.6:35b",
          "description": "Default Ollama model to use"
        },
        "llmPilot.contextLines": {
          "type": "number",
          "default": 80,
          "description": "Max lines of context to send around cursor (token efficiency)"
        },
        "llmPilot.maxTokens": {
          "type": "number",
          "default": 32768,
          "description": "Max tokens per response"
        },
        "llmPilot.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Model temperature (lower = more deterministic)"
        },
        "llmPilot.agentMaxIterations": {
          "type": "number",
          "default": 20,
          "description": "Max tool-use iterations per agent run"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "llmPilot.inlineEdit",
          "when": "editorHasSelection",
          "group": "llmPilot"
        },
        {
          "command": "llmPilot.explainCode",
          "when": "editorHasSelection",
          "group": "llmPilot"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.116.0",
    "typescript": "^5.9.3"
  }
}
